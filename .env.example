# Webflow Data API v2 credentials.
# Copy this file to `.env.local` and fill in real values to pull live content.
# Without these, the site renders with local mock content (see src/lib/mockData.ts).

# A Webflow site API token with CMS read access (Bearer token).
WEBFLOW_API_TOKEN=

# CMS collection id for the "project" items shown on /design-film.
WEBFLOW_PROJECTS_COLLECTION_ID=

# CMS collection id for the music "releases" shown on /music.
WEBFLOW_RELEASES_COLLECTION_ID=
